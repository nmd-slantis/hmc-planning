# ─── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: restrict login to a specific Google Workspace domain (e.g. slantis.com)
# Leave empty to allow any Google account
ALLOWED_DOMAIN=

# ─── Odoo ───────────────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database_name
ODOO_USERNAME=api@yourcompany.com
ODOO_PASSWORD=your_odoo_password

# ─── HubSpot ────────────────────────────────────────────────────────────────────
# Private App access token (Settings → Integrations → Private Apps)
# Scopes needed: crm.objects.deals.read, crm.objects.companies.read
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxx

# ─── Database ───────────────────────────────────────────────────────────────────
# Local development: SQLite file (used when TURSO_DATABASE_URL is not set)
DATABASE_URL="file:./dev.db"

# Production: Turso (libSQL)
# Sign up at https://turso.tech, create a DB, then:
#   turso db show --url <db-name>   → TURSO_DATABASE_URL
#   turso db tokens create <db-name> → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=
